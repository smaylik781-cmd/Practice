[FORMAT]
max-line-length=100

[BASIC]
fail-under=7.0

[MESSAGES CONTROL]
disable=missing-module-docstring,missing-function-docstring
[FORMAT]
max-line-length=100
# Включаем проверку длины комментариев
ignore-long-lines=^\s*(# )?<?https?://\S+>?$

[MESSAGES CONTROL]
# Убедитесь, что C0301 (line-too-long) НЕ отключен
enable=line-too-long
